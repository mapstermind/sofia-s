# Google Forms Integration Configuration
# Copy this file to .env and fill in your actual values

# Path to Google Service Account JSON file
# Download from Google Cloud Console > IAM & Admin > Service Accounts
GOOGLE_APPLICATION_CREDENTIALS=path/to/your/service-account.json

# Google Form ID to fetch responses from
# Extract from form URL: https://docs.google.com/forms/d/FORM_ID/edit
GOOGLE_FORM_ID=your-form-id-here

# Cache TTL for form responses (seconds, default: 60)
FORMS_CACHE_SECONDS=60
