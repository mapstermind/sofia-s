# Django settings
SECRET_KEY=your-secret-key-here-generate-with-python-c-"import-secrets;print(secrets.token_hex(50))"
DJANGO_SETTINGS_MODULE=config.settings.development

# Google Sheets API
# Path to a service account JSON credentials file with Sheets read access
GOOGLE_CREDENTIALS_FILE=/path/to/service-account-credentials.json

# Email (for production SMTP; dev uses console backend)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# Production only
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
